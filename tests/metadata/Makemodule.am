libgd_test_programs += \
	metadata/metadata_core \
	metadata/codec_metadata

metadata_codec_metadata_SOURCES = metadata/codec_metadata.c
metadata_codec_metadata_LDADD = libgdtest.a ../src/libgd.la
if HAVE_LIBJPEG
metadata_codec_metadata_CPPFLAGS += -DGD_TEST_HAVE_JPEG
endif
if HAVE_LIBPNG
metadata_codec_metadata_CPPFLAGS += -DGD_TEST_HAVE_PNG
endif
if HAVE_LIBWEBP
metadata_codec_metadata_CPPFLAGS += -DGD_TEST_HAVE_WEBP
endif
if HAVE_LIBAVIF
metadata_codec_metadata_CPPFLAGS += -DGD_TEST_HAVE_AVIF
endif
if HAVE_LIBHEIF
metadata_codec_metadata_CPPFLAGS += -DGD_TEST_HAVE_HEIF
endif
if HAVE_LIBJXL
metadata_codec_metadata_CPPFLAGS += -DGD_TEST_HAVE_JXL
endif
if HAVE_LIBTIFF
metadata_codec_metadata_CPPFLAGS += -DGD_TEST_HAVE_TIFF
endif

if HAVE_LIBJPEG
libgd_test_programs += \
	metadata/jpeg_metadata
endif

if HAVE_LIBEXIV2
libgd_test_programs += \
	metadata/jpeg_exiv2
metadata_jpeg_exiv2_SOURCES = metadata/jpeg_exiv2.cpp
metadata_jpeg_exiv2_LDADD = libgdtest.a ../src/libgd.la $(LIBEXIV2_LIBS)
metadata_jpeg_exiv2_CPPFLAGS = $(AM_CPPFLAGS) $(LIBEXIV2_CFLAGS)
endif

if HAVE_LIBPNG
libgd_test_programs += \
	metadata/png_metadata
endif

if HAVE_LIBPNG
if HAVE_LIBEXIV2
libgd_test_programs += \
	metadata/png_exiv2
metadata_png_exiv2_SOURCES = metadata/png_exiv2.cpp
metadata_png_exiv2_LDADD = libgdtest.a ../src/libgd.la $(LIBEXIV2_LIBS)
metadata_png_exiv2_CPPFLAGS = $(AM_CPPFLAGS) $(LIBEXIV2_CFLAGS)
endif
endif

EXTRA_DIST += \
	metadata/CMakeLists.txt \
	metadata/codec_metadata.c \
	metadata/jpeg_exiv2.cpp \
	metadata/png_exiv2.cpp
